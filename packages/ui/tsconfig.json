{
  "extends": "../../tsconfig.settings.json",
  "include": [
    "./.storybook/**/*",
    "./exports",
    "./scripts",
    "./src",
    "./stories",
    "./test",
    "./tsdown.config.ts",
    "./typings",
    "./workshop",
    "./workshop.config.ts",
    "./workshop.runtime.ts"
  ],
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist/types",
    "types": ["node", "jest"],
    // Setting "jsx" to aynthing but "preserve" is usually incorrect, but at the moment Storybook needs it
    "jsx": "react-jsx"
  }
}
