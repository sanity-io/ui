{
  "extends": "@repo/typescript-config/base.json",
  "include": [
    "./e2e",
    "./exports",
    "./package.json",
    "./package.config.ts",
    "./playwright.config.ts",
    "./scripts",
    "./src",
    "./test",
    "./typings",
    "./vitest.config.ts",
    "./workshop",
    "./workshop.config.ts",
    "./workshop.runtime.ts"
  ],
  "compilerOptions": {
    "rootDir": "..",
    "outDir": "./dist/types",
    "tsBuildInfoFile": "./dist/tsconfig.tsbuildinfo",

    "esModuleInterop": true,

    // Needed for vite 8 (via ui-workshop)
    "jsx": "react-jsx",

    "noEmit": true,
    "resolveJsonModule": true,

    "paths": {
      "$test/*": ["./test/*"],
      "$workshop": ["./workshop"],

      "@sanity/ui": ["./exports/index.ts"],
      "@sanity/ui/*": ["./exports/*"],
      "@sanity/ui-css": ["../ui-css/exports/index.ts"],
      "@sanity/ui-css/*": ["../ui-css/exports/*.ts"],
      "@sanity/ui-tokens": ["../ui-tokens/exports/index.ts"],
      "@sanity/ui-tokens/*": ["../ui-tokens/exports/*.ts"],
      "@sanity/ui-workshop": ["../ui-workshop/exports/index.ts"],
      "@sanity/ui-workshop/*": ["../ui-workshop/exports/*.ts"]
    }
  }
}
