{
  "extends": "@repo/typescript-config/base.json",
  "include": [
    "./cypress.config.ts",
    "./exports",
    "./package.json",
    "./package.config.ts",
    "./src",
    "./test",
    "./typings",
    "./vitest.config.ts",
    "./workshop",
    "./workshop.config.ts",
    "./workshop.runtime.ts"
  ],
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist/types",

    "esModuleInterop": true,
    "noEmit": true,
    "resolveJsonModule": true,

    "paths": {
      "$test/*": ["./test/*"],
      "$workshop": ["./workshop"],

      "@sanity/ui": ["./exports/index.ts"],
      "@sanity/ui/*": ["./exports/*"]
    }
  }
}
