{
  "extends": "@repo/typescript-config/base.json",
  "include": [
    "./cypress.config.ts",
    "./exports",
    "./package.json",
    "./package.config.ts",
    "./src",
    "./test",
    "./typings",
    "./vanilla-extract",
    "./vitest.config.ts",
    "./workshop",
    "./workshop.config.ts",
    "./workshop.runtime.ts"
  ],
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist/types",

    "esModuleInterop": true,
    "noEmit": true,
    "resolveJsonModule": true,

    "paths": {
      "$test/*": ["./test/*"],
      "$workshop": ["./workshop"],
      "@sanity/ui/*": ["./exports/*"],
      "@sanity/ui": ["./exports/index.ts"],
      "@sanity/ui-css": ["../ui-css/exports"],
      "@sanity/ui-css/*": ["../ui-css/exports/*"],
      "@sanity/ui-tokens": ["../ui-tokens/exports"],
      "@sanity/ui-tokens/*": ["../ui-tokens/exports/*"],
      "@sanity/ui-workshop": ["../ui-workshop/exports"],
      "@sanity/ui-workshop/*": ["../ui-workshop/exports/*"]
    }
  }
}
