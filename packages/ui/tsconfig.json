{
  "extends": "../../tsconfig.settings.json",
  "include": [
    "./.storybook/**/*",
    "./exports",
    "./package.config.ts",
    "./scripts",
    "./src",
    "./stories",
    "./test",
    "./typings",
    "./workshop",
    "./workshop.config.ts",
    "./workshop.runtime.ts"
  ],
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist/types",
    "paths": {
      "@sanity/ui/*": ["./exports/*"],
      "@sanity/ui": ["./exports"]
    },
    // Setting "jsx" to aynthing but "preserve" is usually incorrect, but at the moment Storybook needs it
    "jsx": "react-jsx"
  }
}
