{
  "extends": "@repo/typescript-config/base.json",
  "include": ["./exports", "./package.json", "./src", "./typings"],
  "exclude": [
    "./src/**/__fixtures__",
    "./src/**/__mocks__",
    "./src/**/__workshop__",
    "./src/**/*.test.ts",
    "./src/**/*.test.tsx"
  ],
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",

    "resolveJsonModule": true,
    "sourceMap": true,
    "noEmit": false,

    "noCheck": true,

    "paths": {
      "@sanity/ui": ["./exports/index.ts"],
      "@sanity/ui/*": ["./exports/*"]
    }
  }
}
