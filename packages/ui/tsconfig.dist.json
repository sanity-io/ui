{
  "extends": "../../tsconfig.settings.json",
  "include": ["./exports", "./src", "./typings"],
  "exclude": [
    "./src/**/__fixtures__",
    "./src/**/__mocks__",
    "./src/**/__workshop__",
    "./src/**/*.test.ts",
    "./src/**/*.test.tsx"
  ],
  "compilerOptions": {
    "sourceMap": true,
    "rootDir": ".",
    "outDir": "./dist",
    "types": ["node"],
    // The @sanity/pkg-utils v8 build cannot resolve self-references through
    // the `@sanity/ui:source` condition in package.json `exports`
    // (api-extractor does not support `customConditions`, and `dist` does not
    // exist yet during a clean build), so the build keeps explicit `paths`.
    "paths": {
      "@sanity/ui/theme": ["./exports/theme.ts"],
      "@sanity/ui": ["./exports"]
    }
  }
}
