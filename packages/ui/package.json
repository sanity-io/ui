{
  "name": "@sanity/ui",
  "version": "3.4.3",
  "keywords": [
    "components",
    "design-system",
    "primitives",
    "react",
    "sanity",
    "ui"
  ],
  "homepage": "https://www.sanity.io/",
  "bugs": {
    "url": "https://github.com/sanity-io/ui/issues"
  },
  "license": "MIT",
  "author": "Sanity.io <hello@sanity.io>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanity-io/ui.git",
    "directory": "packages/ui"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.cts",
  "typesVersions": {
    "*": {
      "_visual-editing": [
        "./dist/_visual-editing.d.ts"
      ],
      "theme": [
        "./dist/theme.d.ts"
      ]
    }
  },
  "exports": {
    ".": "./exports/index.ts",
    "./_visual-editing": "./exports/_visual-editing.ts",
    "./theme": "./exports/theme.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      },
      "./_visual-editing": {
        "import": "./dist/_visual-editing.js",
        "require": "./dist/_visual-editing.cjs"
      },
      "./theme": {
        "import": "./dist/theme.js",
        "require": "./dist/theme.cjs"
      },
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "prepack": "pnpm build",
    "test": "vitest run",
    "test:watch": "vitest",
    "watch": "tsdown --watch"
  },
  "dependencies": {
    "@floating-ui/react-dom": "^2.1.9",
    "@juggle/resize-observer": "^3.4.0",
    "@sanity/color": "workspace:^",
    "@sanity/icons": "workspace:^",
    "csstype": "^3.2.3",
    "motion": "^12.42.2",
    "react-compiler-runtime": "1.0.0",
    "react-refractor": "catalog:",
    "use-effect-event": "^2.0.3"
  },
  "devDependencies": {
    "@rolldown/plugin-babel": "^0.2.3",
    "@sanity/tsdown-config": "catalog:",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/react-is": "catalog:",
    "babel-plugin-react-compiler": "catalog:",
    "jsdom": "^29.1.1",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-is": "catalog:",
    "rimraf": "catalog:",
    "styled-components": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "unrun": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "vitest-axe": "^1.0.0-pre.5"
  },
  "peerDependencies": {
    "react": "^18 || >=19.0.0-0",
    "react-dom": "^18 || >=19.0.0-0",
    "react-is": "^18 || >=19.0.0-0",
    "styled-components": "^5.2 || ^6"
  },
  "engines": {
    "node": ">=20.19 <22 || >=22.12"
  }
}
