{
  "name": "@sanity/ui",
  "version": "4.0.0-beta.0",
  "keywords": [
    "react",
    "ui",
    "kit",
    "library",
    "primitives",
    "components",
    "utils"
  ],
  "homepage": "https://www.sanity.io/ui",
  "bugs": {
    "url": "https://github.com/sanity-io/ui/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanity-io/ui.git",
    "directory": "packages/ui"
  },
  "license": "MIT",
  "author": "Sanity.io <hello@sanity.io>",
  "sideEffects": [
    "*.css"
  ],
  "type": "module",
  "exports": {
    ".": {
      "source": "./exports/index.ts",
      "default": "./dist/index.js"
    },
    "./css": {
      "source": "./exports/css.ts",
      "default": "./dist/css.js"
    },
    "./css/index.css": "./dist/css/index.css",
    "./package.json": "./package.json",
    "./tokens": {
      "source": "./exports/tokens.ts",
      "default": "./dist/tokens.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "css": [
        "./dist/css.d.ts"
      ],
      "tokens": [
        "./dist/tokens.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "exports",
    "src"
  ],
  "scripts": {
    "prebuild": "tsx scripts/prebuild.ts",
    "build": "run-s pkg:build pkg:check",
    "clean": "rimraf dist",
    "dev": "pnpm workshop:dev",
    "figma:build": "pnpm run --filter 'figma-plugin-sanity-ui' build",
    "format": "prettier --write --cache --ignore-unknown .",
    "lint": "eslint .",
    "prepack": "pnpm build",
    "pkg:build": "NODE_ENV=production pkg build --strict",
    "pkg:check": "pkg --strict",
    "playwright:dev": "PLAYWRIGHT_DEV=true playwright test --ui",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:dev": "PLAYWRIGHT_DEV=true playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsc --build",
    "workshop:build": "rimraf .workshop && workshop build",
    "workshop:dev": "rimraf .workshop && workshop dev",
    "workshop:preview": "workshop preview"
  },
  "browserslist": "extends @sanity/browserslist-config",
  "dependencies": {
    "@floating-ui/react-dom": "^2.1.8",
    "@sanity/color": "^3.0.6",
    "@sanity/icons": "^3.7.4",
    "@sanity/ui-css": "workspace:*",
    "@sanity/ui-tokens": "workspace:*",
    "@vanilla-extract/dynamic": "^2.1.5",
    "csstype": "^3.2.3",
    "motion": "^12.38.0",
    "react-refractor": "^4.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@playwright/test": "^1.59.1",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@sanity/browserslist-config": "^1.0.5",
    "@sanity/pkg-utils": "^10.4.14",
    "@sanity/prettier-config": "^3.0.0",
    "@sanity/ui-workshop": "workspace:*",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-is": "^19.2.0",
    "@vanilla-extract/css": "^1.20.1",
    "@vanilla-extract/vite-plugin": "^5.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.4",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-boundaries": "^5.4.0",
    "jsdom": "^29.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-is": "^19.2.5",
    "refractor": "^5.0.0",
    "rimraf": "^6.1.3",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "6.0.2",
    "vite": "^8.0.8",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4",
    "vitest-axe": "1.0.0-pre.5"
  },
  "peerDependencies": {
    "react": "^19.2",
    "react-dom": "^19.2",
    "react-is": "^19.2"
  },
  "engines": {
    "node": ">=20.19 <22 || >=22.12"
  },
  "publishConfig": {
    "access": "public"
  },
  "esm.sh": {
    "bundle": false
  }
}
