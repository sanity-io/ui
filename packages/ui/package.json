{
  "name": "@sanity/ui",
  "version": "4.0.0-static.46",
  "keywords": [
    "react",
    "ui",
    "kit",
    "library",
    "primitives",
    "components",
    "utils"
  ],
  "homepage": "https://www.sanity.io/ui",
  "bugs": {
    "url": "https://github.com/sanity-io/ui/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanity-io/ui.git"
  },
  "license": "MIT",
  "author": "Sanity.io <hello@sanity.io>",
  "sideEffects": [
    "**/*.css"
  ],
  "type": "module",
  "exports": {
    ".": {
      "source": "./exports/index.ts",
      "default": "./dist/index.js"
    },
    "./css": {
      "source": "./exports/css.ts",
      "default": "./dist/css/index.js"
    },
    "./css/index.css": "./dist/css/index.css",
    "./package.json": "./package.json",
    "./theme": {
      "source": "./exports/theme.ts",
      "default": "./dist/theme.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "css": [
        "./dist/css.d.ts"
      ],
      "theme": [
        "./dist/theme.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "exports",
    "src"
  ],
  "scripts": {
    "build": "run-s clean pkg:build pkg:check",
    "clean": "rimraf dist",
    "cypress:dev": "run-p dev cypress:open",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "dev": "run-p workshop:dev storybook:dev",
    "figma:build": "pnpm run --filter 'figma-plugin-sanity-ui' build",
    "format": "prettier --write --cache --ignore-unknown .",
    "lint": "eslint .",
    "prepack": "pnpm build",
    "pkg:build": "mkdirp dist/css && touch dist/css/index.css && NODE_ENV=production pkg build --strict",
    "pkg:check": "pkg --strict",
    "pkg:watch": "mkdirp dist/css && touch dist/css/index.css && NODE_ENV=production pkg watch --strict",
    "release": "semantic-release",
    "storybook:build": "pnpm run --filter 'sanity-ui-storybook' build",
    "storybook:dev": "pnpm run --filter 'sanity-ui-storybook' dev",
    "test": "vitest run",
    "test:browser": "start-server-and-test 'run-s workshop:build workshop:preview' http://localhost:1337 'run-s cypress:run'",
    "typecheck": "tsc --build",
    "watch": "pkg watch --strict",
    "workshop:build": "workshop build",
    "workshop:clean": "rimraf .workshop",
    "workshop:dev": "run-s workshop:clean && workshop dev",
    "workshop:preview": "workshop preview"
  },
  "browserslist": "extends @sanity/browserslist-config",
  "release": {
    "branches": [
      {
        "name": "v2",
        "range": "2.x",
        "channel": "v2"
      },
      "main",
      {
        "name": "v4",
        "channel": "static",
        "prerelease": "static"
      }
    ],
    "extends": "@sanity/semantic-release-preset"
  },
  "dependencies": {
    "@floating-ui/react-dom": "^2.1.7",
    "@juggle/resize-observer": "^3.4.0",
    "@sanity/color": "^3.0.6",
    "@sanity/icons": "^3.7.4",
    "@vanilla-extract/dynamic": "^2.1.5",
    "csstype": "^3.2.3",
    "motion": "^12.34.3",
    "react-refractor": "^4.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@sanity/browserslist-config": "^1.0.5",
    "@sanity/pkg-utils": "^10.4.4",
    "@sanity/prettier-config": "^3.0.0",
    "@sanity/ui-workshop": "workspace:*",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-is": "^19.2.0",
    "@vanilla-extract/css": "^1.18.0",
    "@vanilla-extract/vite-plugin": "^5.1.4",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/browser": "^4.0.18",
    "babel-plugin-react-compiler": "1.0.0",
    "browserslist-config-baseline": "^0.5.0",
    "cac": "^6.7.14",
    "cypress": "^13.17.0",
    "cypress-real-events": "^1.15.0",
    "cz-conventional-changelog": "^3.3.0",
    "dotenv-flow": "^4.1.0",
    "eslint": "^9.39.3",
    "eslint-plugin-boundaries": "^5.4.0",
    "jsdom": "^28.1.0",
    "mkdirp": "^3.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-is": "^19.2.4",
    "refractor": "^5.0.0",
    "rimraf": "^5.0.10",
    "semantic-release": "24.2.7",
    "start-server-and-test": "^2.1.3",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18",
    "vitest-axe": "1.0.0-pre.5"
  },
  "peerDependencies": {
    "react": "^19.2",
    "react-dom": "^19.2",
    "react-is": "^19.2"
  },
  "engines": {
    "node": ">=20.19 <22 || >=22.12"
  },
  "publishConfig": {
    "access": "public"
  },
  "esm.sh": {
    "bundle": false
  }
}
