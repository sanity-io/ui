{
  "extends": "../../tsconfig.settings.json",
  "include": ["./src", "../ui/typings"],
  "compilerOptions": {
    "rootDir": "..",
    "outDir": "./dist/types",
    "types": ["node"],
    // Resolve `@sanity/ui` to its TypeScript source through the
    // `@sanity/ui:source` condition in package.json `exports`, instead of
    // tsconfig `paths` mappings.
    "customConditions": ["@sanity/ui:source"]
  }
}
