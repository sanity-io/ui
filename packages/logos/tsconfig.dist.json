{
  "extends": "../../tsconfig.settings.json",
  "include": ["./src"],
  "compilerOptions": {
    "sourceMap": true,
    "rootDir": ".",
    "outDir": "./dist",
    "types": ["node"],
    // The shared settings use "preserve" (for Storybook), but the tsdown
