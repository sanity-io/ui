    "tsdown": "catalog:",
    "typescript": "catalog:",
    "unrun": "catalog:"
  },
  "peerDependencies": {
    "react": "^18.3 || ^19.0.0-0"
  },
  "engines": {
    "node": ">=14.0.0"
  }
