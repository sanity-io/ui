  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanity-io/ui.git",
    "directory": "packages/logos"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
