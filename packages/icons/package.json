{
  "name": "@sanity/icons",
  "version": "3.8.0",
  "description": "The Sanity icons.",
  "keywords": [
    "icons",
    "sanity",
    "ui"
  ],
  "homepage": "https://www.sanity.io/",
  "bugs": {
    "url": "https://github.com/sanity-io/icons/issues"
  },
  "license": "MIT",
  "author": "Sanity.io <hello@sanity.io>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanity-io/icons.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "require": "./dist/index.cjs",
        "default": "./dist/index.js"
      },
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "blueprint:deploy": "sanity blueprints deploy",
    "build": "pkg build --strict --clean --check",
    "build:showcase": "vite build",
    "clean": "rimraf dist",
    "dev": "vite",
    "embeddings:enable": "sanity datasets embeddings enable icons --projection '{ filename, namedExport, tags, description }' --wait",
    "format": "oxfmt .",
    "generate": "rimraf src/icons && node scripts/generate.ts",
    "knip": "knip",
    "lint": "oxlint",
    "prebuild": "pnpm generate",
    "prepare": "pnpm generate",
    "prepublishOnly": "pnpm build",
    "preview": "vite preview",
    "release": "changeset publish",
    "schema:deploy": "sanity schema deploy",
    "seed:icons": "node scripts/seed-icons-dataset.ts",
    "studio:build": "sanity build",
    "studio:deploy": "sanity deploy --schema-required",
    "studio:dev": "sanity dev",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@resvg/resvg-js": "^2.6.2",
    "@rolldown/plugin-babel": "^0.2.3",
    "@sanity/blueprints": "^0.21.0",
    "@sanity/client": "^7.23.0",
    "@sanity/functions": "^1.4.0",
    "@sanity/pkg-utils": "^10.8.1",
    "@sanity/tsconfig": "^2.1.0",
    "@sanity/ui": "^3.3.0",
    "@svgr/core": "^8.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "camelcase": "^8.0.0",
    "globby": "^14.1.0",
    "jsdom": "^29.1.1",
    "knip": "^6.23.0",
    "lefthook": "^2.1.9",
    "mkdirp": "^3.0.1",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "oxlint-tsgolint": "^0.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-is": "^19.2.7",
    "react-refractor": "^4.0.0",
    "refractor": "^5.0.0",
    "rimraf": "^6.0.1",
    "sanity": "^6.3.0",
    "sanity-plugin-media": "^5.0.5",
    "styled-components": "^6.4.3",
    "typescript": "5.9.3",
    "vite": "^8.1.2",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "react": "^18.3 || ^19.0.0-0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.0.0",
      "onFail": "download"
    }
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "packageManager": "pnpm@11.9.0",
  "esm.sh": {
    "bundle": false
  }
}
