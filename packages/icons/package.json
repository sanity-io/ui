{
  "name": "@sanity/icons",
  "version": "3.7.6",
  "description": "The Sanity icons.",
  "keywords": [
    "icons",
    "sanity",
    "ui"
  ],
  "homepage": "https://www.sanity.io/",
  "bugs": {
    "url": "https://github.com/sanity-io/icons/issues"
  },
  "license": "MIT",
  "author": "Sanity.io <hello@sanity.io>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanity-io/icons.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "require": "./dist/index.cjs",
        "default": "./dist/index.js"
      },
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "run-s clean generate pkg:build pkg:check",
    "clean": "rimraf .workshop dist",
    "dev": "pnpm workshop:dev",
    "format": "oxfmt .",
    "generate": "rimraf src/icons && node scripts/generate.ts",
    "lint": "oxlint",
    "pkg:build": "pkg build --strict",
    "pkg:check": "pkg --strict",
    "pkg:watch": "pkg watch --strict",
    "prepublishOnly": "pnpm build",
    "release": "changeset publish",
    "test": "jest",
    "ts:check": "tsc",
    "workshop:build": "workshop build",
    "workshop:dev": "workshop dev"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-react": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@sanity/pkg-utils": "^10.8.1",
    "@sanity/tsconfig": "^2.1.0",
    "@sanity/ui": "^3.1.10",
    "@sanity/ui-workshop": "^3.4.0",
    "@svgr/core": "^8.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.18.10",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vanilla-extract/css": "^1.17.4",
    "babel-plugin-react-compiler": "19.1.0-rc.3",
    "camelcase": "^8.0.0",
    "esbuild": "^0.25.11",
    "esbuild-register": "^3.6.0",
    "globby": "^14.1.0",
    "jest": "^30.2.0",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^30.2.0",
    "lefthook": "^2.1.9",
    "mkdirp": "^3.0.1",
    "module-alias": "^2.2.3",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "oxlint-tsgolint": "^0.23.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-is": "^19.2.1",
    "rimraf": "^6.0.1",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "react": "^18.3 || ^19.0.0-0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.0.0",
      "onFail": "download"
    }
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "packageManager": "pnpm@11.9.0",
  "esm.sh": {
    "bundle": false
  }
}
