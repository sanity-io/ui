{
  "name": "@sanity/icons",
  "version": "3.7.6",
  "description": "The Sanity icons.",
  "keywords": [
    "icons",
    "sanity",
    "ui"
  ],
  "homepage": "https://www.sanity.io/",
  "bugs": {
    "url": "https://github.com/sanity-io/icons/issues"
  },
  "license": "MIT",
  "author": "Sanity.io <hello@sanity.io>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanity-io/icons.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "require": "./dist/index.cjs",
        "default": "./dist/index.js"
      },
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "run-s clean generate pkg:build pkg:check",
    "build:showcase": "vite build",
    "clean": "rimraf dist",
    "dev": "vite",
    "format": "oxfmt .",
    "generate": "rimraf src/icons && node scripts/generate.ts",
    "knip": "knip",
    "lint": "oxlint",
    "pkg:build": "pkg build --strict",
    "pkg:check": "pkg --strict",
    "pkg:watch": "pkg watch --strict",
    "prepublishOnly": "pnpm build",
    "preview": "vite preview",
    "release": "changeset publish",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@sanity/pkg-utils": "^10.8.1",
    "@sanity/tsconfig": "^2.1.0",
    "@sanity/ui": "^3.1.10",
    "@svgr/core": "^8.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.18.10",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "camelcase": "^8.0.0",
    "globby": "^14.1.0",
    "jsdom": "^29.1.1",
    "knip": "^6.23.0",
    "lefthook": "^2.1.9",
    "mkdirp": "^3.0.1",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "oxlint-tsgolint": "^0.23.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-is": "^19.2.1",
    "rimraf": "^6.0.1",
    "typescript": "5.9.3",
    "vite": "^8.1.2",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "react": "^18.3 || ^19.0.0-0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.0.0",
      "onFail": "download"
    }
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "packageManager": "pnpm@11.9.0",
  "esm.sh": {
    "bundle": false
  }
}
