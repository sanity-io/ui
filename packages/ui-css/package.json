{
  "name": "@sanity/ui-css",
  "version": "0.0.0",
  "keywords": [
    "sanity",
    "ui",
    "css"
  ],
  "homepage": "https://www.sanity.io/",
  "bugs": {
    "url": "https://github.com/sanity-io/ui/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanity-io/ui.git",
    "directory": "packages/ui-css"
  },
  "license": "MIT",
  "author": "Sanity.io <hello@sanity.io>",
  "sideEffects": [
    "*.css"
  ],
  "type": "module",
  "exports": {
    ".": {
      "source": "./exports/index.ts",
      "import": "./dist/index.js"
    },
    "./index.css": "./dist/index.css",
    "./package.json": "./package.json",
    "./vanilla-extract": {
      "source": "./exports/vanilla-extract.ts",
      "import": "./dist/vanilla-extract.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "run-s clean",
    "build": "run-s pkg:build",
    "clean": "rimraf dist",
    "dev": "workshop dev",
    "lint": "eslint . --ext .cjs,.js,.jsx,.mjs,.ts,.tsx",
    "prepack": "run-s build",
    "pkg:build": "mkdirp dist && touch dist/index.css && pkg build --strict",
    "test": "vitest --passWithNoTests",
    "tsc:build": "tsc --build",
    "typecheck": "run-s tsc:build",
    "watch": "pkg watch --strict"
  },
  "browserslist": "extends @sanity/browserslist-config",
  "dependencies": {
    "@sanity/ui-tokens": "workspace:*"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@sanity/browserslist-config": "^1.0.5",
    "@sanity/icons": "^3.7.4",
    "@sanity/pkg-utils": "^10.4.4",
    "@sanity/tsconfig": "^2.1.0",
    "@types/node": "^24.10.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-is": "^19.2.0",
    "@vanilla-extract/css": "^1.18.0",
    "@vanilla-extract/vite-plugin": "^5.1.4",
    "dotenv-flow": "^4.1.0",
    "eslint": "^9.39.2",
    "mkdirp": "^3.0.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-refractor": "^4.0.0",
    "refractor": "^5.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.js"
      },
      "./index.css": "./dist/index.css",
      "./package.json": "./package.json",
      "./vanilla-extract": {
        "import": "./dist/vanilla-extract.js"
      }
    }
  }
}
