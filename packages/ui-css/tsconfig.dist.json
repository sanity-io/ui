{
  "extends": "@repo/typescript-config/base.json",
  "include": ["./exports", "./src", "./vanilla-extract"],
  "exclude": ["./src/**/*.test.ts", "./src/**/__tests__/**"],
  "compilerOptions": {
    "composite": true,

    "rootDir": ".",
    "outDir": "./dist",

    "noCheck": true,

    "paths": {
      "@sanity/ui-css": ["./exports/index.ts"],
      "@sanity/ui-css/*": ["./exports/*"]
    }
  }
}
