{
  "extends": "@sanity/tsconfig/strictest",
  "display": "Base",
  "compilerOptions": {
    "target": "ESNext",
    "module": "Preserve",
    "jsx": "preserve",

    "allowImportingTsExtensions": false,
    "exactOptionalPropertyTypes": false,
    "noEmit": false,
    "noUncheckedIndexedAccess": false
  }
}
