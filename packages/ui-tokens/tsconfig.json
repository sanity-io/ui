{
  "extends": "@repo/typescript-config/base.json",
  "include": ["./exports", "./package.config.ts", "./scripts", "./src"],
  "exclude": ["./src/main/system.ts"],
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",
    "tsBuildInfoFile": "./dist/tsconfig.tsbuildinfo",
    "types": ["node"],
    "noEmit": true,
    "paths": {
      "@sanity/ui-tokens": ["./exports/index.ts"],
      "@sanity/ui-tokens/*": ["./exports/*"]
    }
  }
}
