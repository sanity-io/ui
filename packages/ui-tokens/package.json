{
  "name": "@sanity/ui-tokens",
  "version": "0.0.0",
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "source": "./exports/index.ts",
      "import": "./dist/index.js"
    },
    "./system": {
      "source": "./exports/system.ts",
      "import": "./dist/system.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "etc"
  ],
  "scripts": {
    "prebuild": "run-s clean",
    "build": "run-s generate pkg:build tokens-studio:generate",
    "clean": "rimraf dist etc",
    "figma:deploy": "tsx scripts/figma/deploy.ts",
    "generate": "tsx scripts/generate.ts",
    "lint": "eslint . --ext .cjs,.js,.jsx,.mjs,.ts,.tsx",
    "prepack": "run-s build",
    "pkg:build": "pkg build --strict",
    "test": "vitest --passWithNoTests",
    "tokens-studio:generate": "tsx scripts/tokens-studio/generate.ts",
    "tsc:build": "tsc --build",
    "typecheck": "run-s generate tsc:build"
  },
  "browserslist": "extends @sanity/browserslist-config",
  "dependencies": {
    "@sanity/color": "^3.0.6",
    "colorjs.io": "^0.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@sanity/browserslist-config": "^1.0.5",
    "@sanity/pkg-utils": "^10.4.4",
    "@sanity/tsconfig": "^2.1.0",
    "@types/node": "^24.10.13",
    "dotenv-flow": "^4.1.0",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.js"
      },
      "./system": {
        "import": "./dist/system.js"
      },
      "./package.json": "./package.json"
    }
  }
}
