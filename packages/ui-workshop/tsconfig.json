{
  "extends": "@repo/typescript-config/base.json",
  "include": [
    "./exports",
    "./package.json",
    "./package.config.ts",
    "./rollup",
    "./scripts",
    "./src",
    "./vanilla-extract",
    "./workshop.config.ts",
    "./workshop.runtime.ts"
  ],
  "compilerOptions": {
    "rootDir": "..",
    "outDir": "./dist",
    "tsBuildInfoFile": "./dist/tsconfig.tsbuildinfo",

    "noEmit": true,

    "paths": {
      "@sanity/ui/*": ["../ui/exports/*"],
      "@sanity/ui": ["../ui/exports/index.ts"],
      "@sanity/ui-css/*": ["../ui-css/exports/*"],
      "@sanity/ui-css": ["../ui-css/exports/index.ts"],
      "@sanity/ui-tokens": ["../ui-tokens/exports/index.ts"],
      "@sanity/ui-tokens/*": ["../ui-tokens/exports/*"],
      "@sanity/ui-workshop/*": ["./exports/*.ts"],
      "@sanity/ui-workshop": ["./exports"]
    }
  }
}
