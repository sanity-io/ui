{
  "extends": "./tsconfig.settings",
  "include": ["./exports", "./package.json", "./src", "./typings"],
  "exclude": [
    "./src/**/__fixtures__",
    "./src/**/__mocks__",
    "./src/**/__workshop__",
    "./src/**/*.test.ts",
    "./src/**/*.test.tsx"
  ],
  "compilerOptions": {
    "jsx": "preserve",
    "rootDir": ".",
    "outDir": "./dist",
    "noCheck": true
  }
}
