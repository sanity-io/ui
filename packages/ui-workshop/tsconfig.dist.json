{
  "extends": "@repo/typescript-config/base.json",
  "include": ["./exports", "./package.json", "./src"],
  "exclude": [
    "./src/**/__fixtures__",
    "./src/**/__mocks__",
    "./src/**/__workshop__",
    "./src/**/*.test.ts",
    "./src/**/*.test.tsx"
  ],
  "compilerOptions": {
    "rootDir": "..",
    "outDir": "./dist",
    "tsBuildInfoFile": "./dist/tsconfig.dist.tsbuildinfo",

    "noCheck": true,

    "paths": {
      "@sanity/ui": ["../ui/exports"],
      "@sanity/ui/*": ["../ui/exports/*"],
      "@sanity/ui-css": ["../ui-css/exports"],
      "@sanity/ui-css/*": ["../ui-css/exports/*"],
      "@sanity/ui-tokens": ["../ui-tokens/exports"],
      "@sanity/ui-tokens/*": ["../ui-tokens/exports/*"],
      "@sanity/ui-workshop": ["./exports"],
      "@sanity/ui-workshop/*": ["./exports/*.ts"]
    }
  }
}
