{
  "name": "@sanity/ui-workshop",
  "version": "3.4.0",
  "keywords": [
    "sanity",
    "ui",
    "design",
    "design system",
    "prototyping",
    "testing",
    "qa"
  ],
  "homepage": "https://www.sanity.io/",
  "bugs": {
    "url": "https://github.com/sanity-io/ui-workshop/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanity-io/ui-workshop.git"
  },
  "license": "MIT",
  "author": "Sanity.io <hello@sanity.io>",
  "type": "module",
  "imports": {
    "#styles": "./src/core/styles.css.ts"
  },
  "exports": {
    ".": {
      "source": "./exports/index.ts",
      "node": {
        "default": "./dist/index.node.js"
      },
      "default": "./dist/index.js"
    },
    "./plugin-a11y": {
      "source": "./exports/plugin-a11y.ts",
      "default": "./dist/plugin-a11y.js"
    },
    "./plugin-perf": {
      "source": "./exports/plugin-perf.ts",
      "default": "./dist/plugin-perf.js"
    },
    "./runtime": {
      "source": "./exports/runtime.ts",
      "default": "./dist/runtime.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "plugin-a11y": [
        "./dist/plugin-a11y.d.ts"
      ],
      "plugin-perf": [
        "./dist/plugin-perf.d.ts"
      ],
      "runtime": [
        "./dist/runtime.d.ts"
      ]
    }
  },
  "bin": {
    "workshop": "./bin/workshop.js"
  },
  "files": [
    "bin",
    "dist",
    "exports",
    "src"
  ],
  "scripts": {
    "prebuild": "pnpm clean",
    "build": "NODE_ENV=production pkg build --check --strict",
    "clean": "rimraf dist",
    "dev": "pnpm workshop:dev",
    "format": "prettier --write --cache --ignore-unknown .",
    "lint": "eslint . --ext .cjs,.js,.jsx,.mjs,.ts,.tsx",
    "prepack": "pnpm build",
    "prepare": "husky",
    "release": "changeset publish",
    "test": "vitest",
    "typecheck": "tsc --build",
    "watch": "pkg watch --strict",
    "workshop:build": "run-s clean && node -r dotenv-flow/config -r esbuild-register -r tsconfig-paths/register scripts/build",
    "workshop:dev": "node -r dotenv-flow/config -r esbuild-register -r tsconfig-paths/register scripts/dev",
    "workshop:start": "http-server -a localhost -c-0 -p 1337 -s -P http://localhost:1337/index.html? dist"
  },
  "lint-staged": {
    "*": [
      "prettier --write --cache --ignore-unknown"
    ]
  },
  "browserslist": "extends @sanity/browserslist-config",
  "dependencies": {
    "@sanity/icons": "^3.7.4",
    "@vanilla-extract/vite-plugin": "^5.1.4",
    "@vitejs/plugin-react": "^5.1.1",
    "axe-core": "^4.11.0",
    "cac": "^6.7.14",
    "chokidar": "^3.6.0",
    "cpx": "^1.5.0",
    "dotenv-flow": "^4.1.0",
    "esbuild": "^0.27.0",
    "esbuild-register": "^3.6.0",
    "express": "^5.1.0",
    "globby": "^11.1.0",
    "lodash": "^4.17.21",
    "mkdirp": "^2.1.6",
    "pako": "^2.1.0",
    "rimraf": "^4.4.1",
    "segmented-property": "^4.0.0",
    "vite": "^7.2.4"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.7",
    "@eslint/js": "^9.37.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
    "@sanity/browserslist-config": "^1.0.5",
    "@sanity/pkg-utils": "^10.3.0",
    "@sanity/prettier-config": "^3.0.0",
    "@sanity/tsconfig": "^2.1.0",
    "@sanity/ui": "^3.1.11",
    "@types/cpx": "^1.5.6",
    "@types/express": "^5.0.5",
    "@types/lodash": "^4.17.21",
    "@types/node": "^20.19.25",
    "@types/pako": "^2.0.4",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vanilla-extract/css": "^1.18.0",
    "@vanilla-extract/css-utils": "^0.1.6",
    "@vanilla-extract/dynamic": "^2.1.5",
    "@vanilla-extract/integration": "^8.0.7",
    "babel-plugin-react-compiler": "1.0.0",
    "browserslist": "^4.28.1",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-formatter-gha": "^2.0.1",
    "eslint-plugin-boundaries": "^5.3.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^17.0.0",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "jsdom": "^22.1.0",
    "lightningcss": "^1.30.2",
    "magic-string": "^0.30.21",
    "npm-run-all2": "^6.2.6",
    "prettier": "^3.7.4",
    "prettier-plugin-packagejson": "^2.5.21",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-is": "^19.2.0",
    "rollup": "^4.55.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.52.0",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "@sanity/ui": "^3",
    "react": "^19",
    "react-dom": "^19"
  },
  "packageManager": "pnpm@10.28.0",
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "node": {
          "default": "./dist/index.node.js"
        },
        "default": "./dist/index.js"
      },
      "./plugin-a11y": "./dist/plugin-a11y.js",
      "./plugin-perf": "./dist/plugin-perf.js",
      "./runtime": "./dist/runtime.js",
      "./package.json": "./package.json"
    }
  },
  "esm.sh": {
    "bundle": false
  }
}
