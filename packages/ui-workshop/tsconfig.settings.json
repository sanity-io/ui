{
  "extends": "@sanity/tsconfig/strictest",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",

    "allowImportingTsExtensions": false,
    "exactOptionalPropertyTypes": false,
    "noUncheckedIndexedAccess": false,

    "paths": {
      "@sanity/ui-workshop": ["./exports/index.ts"],
      "@sanity/ui-workshop/*": ["./exports/*"]
    }
  }
}
