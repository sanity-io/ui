{
  "extends": "@repo/typescript-config/base.json",
  "include": ["./src", "./package.config.ts"],
  "compilerOptions": {
    "target": "ES6",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noEmit": true,
    "rootDir": "../..",
    "outDir": "./dist",
    "tsBuildInfoFile": "./dist/tsconfig.tsbuildinfo",
    "typeRoots": ["./node_modules/@types", "./node_modules/@figma"],
    "paths": {
      "@sanity/ui-tokens": ["../../packages/ui-tokens/exports/index.ts"],
      "@sanity/ui-tokens/*": ["../../packages/ui-tokens/exports/*"]
    }
  }
}
