{
  "name": "sanity-ui-docs",
  "version": "2.0.0",
  "private": true,
  "license": "MIT",
  "imports": {
    "#app/*": "./src/app/*",
    "#lib/*": "./src/lib/*",
    "#sanity.types": "./sanity.types.ts",
    "#context/*": "./src/context/*.tsx"
  },
  "scripts": {
    "build": "pnpm sanity:build && pnpm next:build",
    "dev": "pnpm run \"/:dev$/\"",
    "embeddings:enable": "sanity datasets embeddings enable production --projection '{ filename, namedExport, tags, description }' --wait",
    "next:build": "next build --turbopack",
    "next:dev": "next dev --turbopack",
    "prepare": "next typegen",
    "sanity:build": "sanity build public/studio",
    "sanity:dev": "sanity dev",
    "start": "next start",
    "test": "vitest",
    "typecheck": "tsc --build"
  },
  "dependencies": {
    "@babel/standalone": "^7.29.7",
    "@codemirror/lang-javascript": "^6.2.5",
    "@lezer/highlight": "^1.2.3",
    "@sanity/client": "catalog:",
    "@sanity/code-input": "^7.2.10",
    "@sanity/color": "catalog:",
    "@sanity/icons": "catalog:",
    "@sanity/image-url": "^2.1.1",
    "@sanity/logos": "^2.2.2",
    "@sanity/ui": "workspace:*",
    "@sanity/vision": "^6.5.0",
    "@sindresorhus/slugify": "^2.2.1",
    "@uiw/codemirror-themes": "^4.25.11",
    "@uiw/react-codemirror": "^4.25.11",
    "lodash-es": "^4.18.1",
    "next": "16.3.0-preview.6",
    "next-sanity": "^13.1.4",
    "pako": "^2.2.0",
    "prettier": "^3.9.5",
    "qs": "^6.15.3",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-refractor": "catalog:",
    "refractor": "catalog:",
    "sanity": "catalog:",
    "sanity-plugin-media": "^6.0.4",
    "server-only": "^0.0.1",
    "styled-components": "catalog:"
  },
  "devDependencies": {
    "@types/babel__standalone": "^7.1.9",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.13.3",
    "@types/pako": "^2.0.4",
    "@types/qs": "^6.15.1",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "babel-plugin-react-compiler": "catalog:",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
