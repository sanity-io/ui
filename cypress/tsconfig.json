{
  "extends": "../tsconfig.settings.json",
  "compilerOptions": {
    // Cypress's bundled webpack preprocessor injects `downlevelIteration`,
    // which TypeScript 6 rejects (TS5101) unless silenced
    "ignoreDeprecations": "6.0",
    "target": "es2017",
    "lib": ["es2017", "dom"],
    "types": ["cypress", "cypress-real-events", "node"]
  },
  "include": ["./**/*.ts"]
}
