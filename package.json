{
  "name": "sanity-ui-monorepo",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "author": "Sanity.io <hello@sanity.io>",
  "scripts": {
    "build": "pnpm --filter @sanity/color build && pnpm --filter @sanity/icons build && pnpm --filter @sanity/logos build && pnpm --filter @sanity/ui build && pnpm --filter figma-plugin-sanity-ui build && pnpm --filter figma-plugin-sanity-color build",
    "changeset": "changeset",
    "clean": "pnpm --recursive clean",
    "dev": "pnpm --filter sanity-ui-storybook dev",
    "dev:docs": "pnpm --filter sanity-ui-docs dev",
    "dev:icons": "pnpm --filter sanity-icons-showcase dev",
    "format": "oxfmt . --no-error-on-unmatched-pattern",
    "knip": "knip --treat-config-hints-as-errors",
    "lint": "pnpm run oxlint",
    "lint:fix": "pnpm lint --fix --fix-suggestions",
    "oxlint": "oxlint --disable-nested-config",
    "release": "changeset publish",
    "storybook:build": "pnpm --filter sanity-ui-storybook build",
    "test": "pnpm --filter @sanity/color --filter @sanity/icons --filter @sanity/ui test",
    "test:browser": "pnpm --filter sanity-ui-storybook test",
    "watch": "pnpm --filter @sanity/ui watch"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.1",
    "@types/node": "catalog:",
    "eslint-plugin-storybook": "^10.5.3",
    "knip": "^6.29.0",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^0.24.0",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=22.13"
  },
  "packageManager": "pnpm@11.10.0"
}
