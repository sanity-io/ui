{
  "name": "sanity-ui-system",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "turbo build --filter=./packages/*",
    "commit": "cz",
    "dev": "turbo dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo lint",
    "prepare": "husky install",
    "test": "turbo test -- --run",
    "typecheck": "turbo typecheck"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*": [
      "prettier --write --cache --ignore-unknown"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@sanity/pkg-utils": "^8.1.24",
    "@sanity/prettier-config": "^3.0.0",
    "commitizen": "^4.3.1",
    "husky": "^8.0.3",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^3.0.0",
    "rimraf": "^6.1.2",
    "tsx": "^4.21.0",
    "turbo": "^2.7.6",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.20.0",
  "engines": {
    "node": ">=24"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "core-js@2.6.12",
      "cypress@13.17.0",
      "esbuild@0.25.11",
      "esbuild@0.27.3",
      "fsevents@1.2.13",
      "sharp@0.34.4",
      "unrs-resolver@1.11.1"
    ],
    "overrides": {
      "@types/react": "19.2.9",
      "@types/react-dom": "19.2.3",
      "commander": "^13.1.0",
      "zod": "^4.3.6"
    }
  }
}
