{
  "name": "sanity-ui-system",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "turbo build --filter=./packages/*",
    "changeset": "changeset",
    "changeset:publish": "changeset publish",
    "changeset:status": "changeset status",
    "changeset:version": "changeset version",
    "commit": "cz",
    "dev": "turbo dev --ui=tui",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo lint",
    "prepare": "husky",
    "storybook:build": "(cd apps/storybook && pnpm build) && cpx 'apps/storybook/storybook-static/**' storybook/storybook-static/",
    "test": "turbo test -- --run",
    "test:e2e": "turbo test:e2e",
    "typecheck": "turbo typecheck --filter=./packages/*",
    "workshop:build": "pnpm --filter ./packages/ui workshop:build && cpx 'packages/ui/.workshop/dist/**' dist/"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*": [
      "prettier --write --cache --ignore-unknown"
    ]
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@sanity/pkg-utils": "^10.4.14",
    "@sanity/prettier-config": "^3.0.0",
    "@sanity/tsconfig": "^2.1.0",
    "@sanity/ui-workshop": "workspace:*",
    "commitizen": "^4.3.1",
    "cpx": "^1.5.0",
    "husky": "^9.1.7",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.2",
    "prettier-plugin-packagejson": "^3.0.2",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "turbo": "^2.9.6",
    "typescript": "^6.0.2"
  },
  "packageManager": "pnpm@10.30.2",
  "engines": {
    "node": ">=24"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "core-js@2.6.12",
      "esbuild@0.25.11",
      "esbuild@0.27.3",
      "fsevents@1.2.13",
      "sharp@0.34.4",
      "unrs-resolver@1.11.1"
    ],
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3",
      "commander": "^13.1.0",
      "conventional-changelog-conventionalcommits": ">= 8.0.0",
      "zod": "^4.3.6"
    },
    "patchedDependencies": {
      "react-refractor": "patches/react-refractor.patch"
    }
  }
}
