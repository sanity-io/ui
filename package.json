{
  "name": "sanity-ui-monorepo",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "author": "Sanity.io <hello@sanity.io>",
  "scripts": {
    "build": "pnpm --filter @sanity/ui build && pnpm --filter figma-plugin-sanity-ui build",
    "changeset": "changeset",
    "clean": "pnpm --recursive clean",
    "dev": "pnpm --filter sanity-ui-storybook dev",
    "format": "oxfmt . --no-error-on-unmatched-pattern",
    "lint": "pnpm --recursive lint",
    "release": "changeset publish",
    "storybook:build": "pnpm --filter sanity-ui-storybook build",
    "storybook:start": "http-server apps/storybook/storybook-static -a localhost -c-0 -p 6006 -s",
    "test": "pnpm --filter @sanity/ui test",
    "test:browser": "playwright test",
    "test:browser:ui": "playwright test --ui",
    "ts:check": "pnpm --recursive ts:check",
    "watch": "pnpm --filter @sanity/ui watch"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.18.1",
    "http-server": "^14.1.1",
    "lint-staged": "^14.0.1",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.57.0",
    "rimraf": "^5.0.5",
    "typescript": "5.9.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,jsonc,md}": [
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  },
  "engines": {
    "node": ">=22.13"
  },
  "packageManager": "pnpm@11.9.0",
  "pnpm": {
    "overrides": {
      "@types/react": "^19.2.2",
      "@types/react-dom": "^19.2.2",
      "@types/react-is": "^19.2.0",
      "react": "^19.2.0",
      "react-dom": "^19.2.0",
      "react-is": "^19.2.0"
    }
  }
}
