{
  "name": "sanity-ui-monorepo",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "author": "Sanity.io <hello@sanity.io>",
  "scripts": {
    "build": "pnpm --filter @sanity/ui build && pnpm --filter figma-plugin-sanity-ui build",
    "changeset": "changeset",
    "clean": "rimraf dist storybook",
    "commit": "cz",
    "cypress:dev": "run-p dev cypress:open",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "dev": "pnpm --filter @sanity/ui dev",
    "format": "prettier --write --cache --ignore-unknown .",
    "lint": "pnpm --filter @sanity/ui lint",
    "prepare": "husky install",
    "release": "changeset publish",
    "storybook:build": "pnpm --filter @sanity/ui storybook:build && cpx 'packages/ui/storybook/storybook-static/**' storybook/storybook-static/",
    "test": "pnpm --filter @sanity/ui test",
    "test:browser": "start-server-and-test 'run-s workshop:build workshop:start' http://localhost:1337 'run-s cypress:run'",
    "ts:check": "pnpm --filter @sanity/ui ts:check",
    "watch": "pnpm --filter @sanity/ui watch",
    "workshop:build": "pnpm --filter @sanity/ui build && pnpm --filter @sanity/ui workshop:build && cpx 'packages/ui/dist/**' dist/",
    "workshop:start": "http-server -a localhost -c-0 -p 1337 -s -P http://localhost:1337/index.html? dist"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*": [
      "prettier --write --cache --ignore-unknown"
    ]
  },
  "prettier": "@sanity/prettier-config",
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@sanity/prettier-config": "^2.0.1",
    "commitizen": "^4.3.1",
    "cpx": "^1.5.0",
    "cypress": "^13.17.0",
    "cypress-real-events": "^1.14.0",
    "cz-conventional-changelog": "^3.3.0",
    "http-server": "^14.1.1",
    "husky": "^8.0.3",
    "lint-staged": "^14.0.1",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.6.2",
    "rimraf": "^5.0.5",
    "start-server-and-test": "^2.1.0"
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=20.19 <22 || >=22.12"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^19.2.2",
      "@types/react-dom": "^19.2.2",
      "@types/react-is": "^19.2.0",
      "conventional-changelog-conventionalcommits": ">= 8.0.0",
      "react": "^19.2.0",
      "react-dom": "^19.2.0",
      "react-is": "^19.2.0"
    }
  }
}
