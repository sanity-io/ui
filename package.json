{
  "name": "sanity-ui-monorepo",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "author": "Sanity.io <hello@sanity.io>",
  "scripts": {
    "build": "pnpm --filter @sanity/ui build && pnpm --filter figma-plugin-sanity-ui build",
    "changeset": "changeset",
    "clean": "rimraf dist storybook",
    "cypress:dev": "run-p dev cypress:open",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "dev": "pnpm --filter @sanity/ui dev",
    "format": "oxfmt . --no-error-on-unmatched-pattern",
    "lint": "pnpm run oxlint",
    "lint:fix": "pnpm lint --fix --fix-suggestions",
    "oxlint": "oxlint --disable-nested-config",
    "release": "changeset publish",
    "storybook:build": "pnpm --filter @sanity/ui storybook:build && cpx 'packages/ui/storybook/storybook-static/**' storybook/storybook-static/",
    "test": "pnpm --filter @sanity/ui test",
    "test:browser": "start-server-and-test 'run-s workshop:build workshop:start' http://localhost:1337 'run-s cypress:run'",
    "watch": "pnpm --filter @sanity/ui watch",
    "workshop:build": "pnpm --filter @sanity/ui workshop:build && cpx 'packages/ui/dist/**' dist/",
    "workshop:start": "http-server -a localhost -c-0 -p 1337 -s -P http://localhost:1337/index.html? dist"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.18.1",
    "cpx": "^1.5.0",
    "cypress": "^13.17.0",
    "cypress-real-events": "^1.14.0",
    "http-server": "^14.1.1",
    "lint-staged": "^14.0.1",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "oxlint-tsgolint": "^0.24.0",
    "rimraf": "^5.0.5",
    "start-server-and-test": "^2.1.0",
    "typescript": "5.9.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,jsonc,md}": [
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  },
  "engines": {
    "node": ">=22.13"
  },
  "packageManager": "pnpm@11.9.0",
  "pnpm": {
    "overrides": {
      "@types/react": "^19.2.2",
      "@types/react-dom": "^19.2.2",
      "@types/react-is": "^19.2.0",
      "react": "^19.2.0",
      "react-dom": "^19.2.0",
      "react-is": "^19.2.0"
    }
  }
}
