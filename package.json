{
  "name": "sanity-ui-system",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "turbo build --filter=./packages/*",
    "changeset": "changeset",
    "changeset:publish": "changeset publish",
    "changeset:status": "changeset status",
    "changeset:version": "changeset version",
    "commit": "cz",
    "dev": "turbo dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo lint",
    "prepare": "husky",
    "test": "turbo test -- --run",
    "test:e2e": "turbo test:e2e",
    "typecheck": "turbo typecheck",
    "workshop:build": "turbo workshop:build --filter=./packages/ui",
    "workshop:preview": "turbo workshop:preview --filter=./packages/ui"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*": [
      "prettier --write --cache --ignore-unknown"
    ]
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@sanity/pkg-utils": "^10.4.4",
    "@sanity/prettier-config": "^3.0.0",
    "@sanity/tsconfig": "^2.1.0",
    "commitizen": "^4.3.1",
    "husky": "^9.1.7",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^3.0.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "turbo": "^2.8.10",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.30.2",
  "engines": {
    "node": ">=24"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "core-js@2.6.12",
      "esbuild@0.25.11",
      "esbuild@0.27.3",
      "fsevents@1.2.13",
      "sharp@0.34.4",
      "unrs-resolver@1.11.1"
    ],
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3",
      "commander": "^13.1.0",
      "conventional-changelog-conventionalcommits": ">= 8.0.0",
      "zod": "^4.3.6"
    },
    "patchedDependencies": {
      "react-refractor": "patches/react-refractor.patch"
    }
  }
}
