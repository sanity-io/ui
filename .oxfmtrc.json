{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "semi": false,
  "singleQuote": true,
  "bracketSpacing": false,
  "quoteProps": "consistent",
  "sortImports": true,
  "sortPackageJson": {"sortScripts": true},
  "ignorePatterns": [
    "dist/**",
    "storybook-static/**",
    "pnpm-lock.yaml",
    "CHANGELOG.md",
    "**/sanity.types.ts"
  ],
  "overrides": [
    {
      "files": [".changeset/*.md"],
      "options": {"singleQuote": false}
    }
  ]
}
