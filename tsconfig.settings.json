{
  "extends": "@sanity/tsconfig/strictest",
  "compilerOptions": {
    "target": "ESNext",
    "module": "Preserve",
    "jsx": "preserve",

    "allowImportingTsExtensions": false,
    "allowJs": false,
    "checkJs": false,
    "declaration": true,
    "exactOptionalPropertyTypes": false,
    "noUncheckedIndexedAccess": false
  }
}
